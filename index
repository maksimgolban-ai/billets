function renderParams(){
  // Основные параметры (единицы: руб/кг для цен, кг для масс, % для долей)
  const main = [
    {key:'C1', lbl:'Цена на лом', unit:'руб/кг'},
    {key:'C2', lbl:'Цена чушки РУСАЛ', unit:'руб/кг'},
    {key:'C3', lbl:'Завалка первички', unit:'кг', isMass: true},
    {key:'F1', lbl:'Завалка общая', unit:'кг', isMass: true},
    {key:'F2', lbl:'Выход годного', unit:'%', isPct: true},
    {key:'F3', lbl:'Выход шлака', unit:'%', isPct: true},
    {key:'F4', lbl:'Угар', unit:'%', isPct: true},
    {key:'F8', lbl:'Выход чушки из шлака', unit:'%', isPct: true}
  ];
  
  const extra = [
    {key:'F7', lbl:'Цена стружки', unit:'руб/кг'},
    {key:'F44', lbl:'Цена лигатуры', unit:'руб/кг'},
    {key:'F45', lbl:'Цена флюсов', unit:'руб/кг'},
    {key:'H44', lbl:'Доля лигатуры', unit:'%', isPct: true},
    {key:'H45', lbl:'Доля флюсов', unit:'%', isPct: true},
    {key:'H49', lbl:'Доля стружки', unit:'%', isPct: true},
    {key:'H50', lbl:'Доля обрези слитков', unit:'%', isPct: true}
  ];
  
  const direct = [
    {key:'G52', lbl:'ФОТ производства', unit:'руб/кг'},
    {key:'G53', lbl:'Энергоносители', unit:'руб/кг'},
    {key:'G54', lbl:'Расходники', unit:'руб/кг'},
    {key:'G61', lbl:'Косвенные расходы', unit:'руб/кг'},
    {key:'F9', lbl:'Переработка шлака', unit:'руб/кг'}
  ];
  
  const makeRow = ({key, lbl, unit, isPct, isMass}) => {
    let rawVal = P[key];
    let displayVal = isPct ? rawVal * 100 : rawVal;
    let step = (isPct || isMass) ? 'any' : 'any';
    let inputType = 'number';
    return `<div class="prow">
      <span class="plbl">${lbl}</span>
      <input class="pinp" type="${inputType}" step="${step}" value="${displayVal}" data-key="${key}" data-pct="${!!isPct}" data-mass="${!!isMass}" onchange="onParam(this)">
      <span class="punit">${unit}</span>
    </div>`;
  };
  
  document.getElementById('p-main').innerHTML = '<div class="pgrid">' + main.map(makeRow).join('') + '</div>';
  document.getElementById('p-extra').innerHTML = extra.map(makeRow).join('') + 
    `<div class="prow"><span class="plbl">Возвраты по цене</span>
    <select class="psel" onchange="P.возвраты_да=this.value==='lom';refresh()">
      <option value="lom" ${P.возвраты_да?'selected':''}>Лом (фикс)</option>
      <option value="shihta" ${!P.возвраты_да?'selected':''}>Шихта</option>
    </select>
    <span class="punit"></span></div>`;
  document.getElementById('p-direct').innerHTML = direct.map(makeRow).join('');
}

function onParam(el){
  const key = el.dataset.key;
  let val = parseFloat(el.value) || 0;
  if(el.dataset.pct === 'true') val = val / 100;
  P[key] = val;
  refresh();
}

function refresh(){
  const r = calc();
  renderKPI(r); renderPie(r); renderProcTable(r); renderBalance(r); renderShihta(r); renderDirect(r); renderFactor(r); renderSlag(r);
}

function showTab(name, btn){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on')); 
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('pg-'+name).classList.add('on'); 
  btn.classList.add('on');
  if(name === 'model') setTimeout(()=>{ if(pieChart) { pieChart.update(); } }, 80);
}

renderParams();
refresh();
</script>
