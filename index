// ------------------------------ КРУГОВАЯ ДИАГРАММА ------------------------------
function renderPie(r) {
  const labels = ['Шлак', 'ФОТ', 'Энергоносители', 'Расходники', 'Угар', 'Лигатура', 'Флюсы', 'Стружка'];
  const data = [r.G74, r.G80, r.G79, r.G78, r.G76, r.G72, r.G73, r.G75];
  const total = data.reduce((s,v)=>s+v,0);
  const colors = ['#3a86ff', '#f4a261', '#2a9d8f', '#e9c46a', '#e76f51', '#a7c957', '#cdb4db', '#ffb3ba'];
  
  if (pieChart) pieChart.destroy();
  const canvas = document.getElementById('pieC');
  const ctx = canvas.getContext('2d');
  
  const smartLeaderPlugin = {
    id: 'smartLeaderLines',
    afterDraw(chart) {
      const {ctx, chartArea: {width, height}} = chart;
      const meta = chart.getDatasetMeta(0);
      if (!meta.data || meta.data.length === 0) return;
      const cx = meta.data[0].x;
      const cy = meta.data[0].y;
      const radiusOuter = meta.data[0].outerRadius;
      const lineStart = radiusOuter + 12;
      const lineEnd = radiusOuter + 44;
      
      ctx.save();
      ctx.font = '500 11px "IBM Plex Mono", monospace';
      ctx.fillStyle = '#f0f4fa';
      ctx.shadowBlur = 0;
      
      let anchors = [];
      for (let i = 0; i < meta.data.length; i++) {
        if (data[i] <= 0.001) continue;
        const arc = meta.data[i];
        const mid = (arc.startAngle + arc.endAngle) / 2;
        const cos = Math.cos(mid);
        const sin = Math.sin(mid);
        const x1 = cx + cos * lineStart;
        const y1 = cy + sin * lineStart;
        const x2base = cx + cos * lineEnd;
        const y2base = cy + sin * lineEnd;
        const side = cos > 0 ? 'right' : 'left';
        const offsetX = side === 'right' ? 22 : -22;
        const x2 = x2base + offsetX;
        let y2 = y2base;
        anchors.push({ i, side, x1, y1, x2, y2, label: labels[i], val: data[i], baseY: y2 });
      }
      for (let iter = 0; iter < 3; iter++) {
        for (let a = 0; a < anchors.length; a++) {
          for (let b = a+1; b < anchors.length; b++) {
            if (Math.abs(anchors[a].y2 - anchors[b].y2) < 24 && anchors[a].side === anchors[b].side) {
              if (anchors[a].y2 < anchors[b].y2) anchors[a].y2 = Math.max(28, anchors[a].y2 - 14);
              else anchors[a].y2 = Math.min(height - 35, anchors[a].y2 + 14);
            }
          }
        }
      }
      for (let a of anchors) {
        ctx.beginPath();
        ctx.moveTo(a.x1, a.y1);
        ctx.lineTo(a.x2, a.y2);
        ctx.strokeStyle = 'rgba(200,220,255,0.8)';
        ctx.lineWidth = 1.5;
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(a.x1, a.y1, 3, 0, 2*Math.PI);
        ctx.fillStyle = '#ffd966';
        ctx.fill();
        ctx.fillStyle = '#ffffff';
        const percent = (a.val/total)*100;
        const text = `${a.label}: ${f2(a.val)} руб/кг (${percent.toFixed(1)}%)`;
        ctx.textAlign = a.side === 'right' ? 'left' : 'right';
        ctx.fillText(text, a.x2 + (a.side === 'right' ? 6 : -6), a.y2 + 4);
      }
      ctx.restore();
    }
  };
  
  pieChart = new Chart(ctx, {
    type: 'doughnut',
    data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 2, borderColor: '#0d1b2e', hoverOffset: 12, cutout: '58%' }] },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      layout: { padding: { top: 25, bottom: 25, left: 25, right: 25 } },
      plugins: {
        legend: { display: false },
        tooltip: { backgroundColor: '#0a1a2c', titleColor: '#fff', bodyColor: '#ccc', callbacks: { label: (ctx) => ` ${ctx.label}: ${f2(ctx.raw)} руб/кг (${((ctx.raw/total)*100).toFixed(1)}%)` } }
      }
    },
    plugins: [smartLeaderPlugin]
  });
}

